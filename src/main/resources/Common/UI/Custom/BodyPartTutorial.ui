// === TUTORIAL ELEMENTS (OUTSIDE BodyPartPanel) ===

$Common = "Common.ui";

@Background = PatchStyle(TexturePath: "MyBackground.png");

Group {
    LayoutMode: Center;

    Group #BodyPartPanel {
        Background: @Background;
        Anchor: (Width: 1115.0001, Height: 859.16675);

        Label #TitleLabel {
            Text: "MortalWounds Tutorial";
            Style: (HorizontalAlignment: Center, FontSize: 20, RenderBold: true, TextColor: #ffffff);
            Anchor: (Width: 500, Height: 30, Top: 20);
        }
        // === VISUAL BODY MODEL ===
        // HEAD
        Group #HeadModel {
            Anchor: (Left: 500, Top: 120, Width: 100, Height: 94.28572);
            Background: #00FF00(1.0);
            LayoutMode: Center;
            Padding: (Full: 0);
        }
        // TORSO
        Group #TorsoModel {
            Anchor: (Left: 478, Top: 236, Width: 144.66666, Height: 259.3335);
            Background: #00FF00(1.0);
            LayoutMode: Center;
            Padding: (Full: 0);
        }
        // RIGHT ARM
        Group #RightArmModel {
            Anchor: (Left: 401.42856, Top: 260, Width: 48.571434, Height: 228.57143);
            Background: #000000(1.0);
            LayoutMode: Center;
            Padding: (Full: 0);
        }
        // LEFT ARM
        Group #LeftArmModel {
            Anchor: (Left: 650, Top: 260, Width: 45.714283, Height: 227.61906);
            Background: #FFFF00(1.0);
            LayoutMode: Center;
            Padding: (Full: 0);
        }
        // RIGHT LEG
        Group #RightLegModel {
            Anchor: (Left: 484, Top: 510, Width: 51.25, Height: 280);
            Background: #00FF00(1.0);
            LayoutMode: Center;
            Padding: (Full: 0);
        }
        // LEFT LEG
        Group #LeftLegModel {
            Anchor: (Left: 563.5, Top: 511.25, Width: 52.5, Height: 280);
            Background: #FF4200(1.0);
            LayoutMode: Center;
            Padding: (Full: 0);
        }
        // === TEXT LABELS - HEALTH ===
        Label #HeadHealth {
            Anchor: (Left: 276, Top: 111.08334, Width: 241.91666, Height: 50.166664);
            Text: "Head: 10/10";
            Style: (FontSize: 20, TextColor: #00FF00, HorizontalAlignment: Center);
        }

        Label #TorsoHealth {
            Anchor: (Left: 607, Top: 171, Width: 238.5, Height: 40.25);
            Text: "Torso: 28/30";
            Style: (FontSize: 20, TextColor: #00FF00, HorizontalAlignment: Center);
        }

        Label #RightArmHealth {
            Anchor: (Left: 178, Top: 324, Width: 248.75, Height: 36.25);
            Text: "R Arm: 0/15";
            Style: (FontSize: 20, TextColor: #000000, HorizontalAlignment: Center);
        }

        Label #LeftArmHealth {
            Anchor: (Left: 680, Top: 327, Width: 218.75, Height: 37.5);
            Text: "L Arm: 15/15";
            Style: (FontSize: 20, TextColor: #00FF00, HorizontalAlignment: Center);
        }

        Label #RightLegHealth {
            Anchor: (Left: 190, Top: 620, Width: 261.25, Height: 32);
            Text: "R Leg: 15/15";
            Style: (FontSize: 20, TextColor: #00FF00, HorizontalAlignment: Center);
        }

        Label #LeftLegHealth {
            Anchor: (Left: 626, Top: 619, Width: 226, Height: 35);
            Text: "L Leg: 2/15";
            Style: (FontSize: 20, TextColor: #ff1111, HorizontalAlignment: Center);
        }
        // === FRACTURE STATUS LABELS ===
        Label #HeadFracture {
            Anchor: (Left: 45, Top: 65, Width: 100, Height: 15);
            Text: "";
            Style: (FontSize: 9, TextColor: #FFA500, HorizontalAlignment: Center);
        }

        Label #TorsoFracture {
            Anchor: (Left: 370, Top: 95, Width: 100, Height: 15);
            Text: "";
            Style: (FontSize: 9, TextColor: #FFA500, HorizontalAlignment: Center);
        }

        Label #RightArmFracture {
            Anchor: (Left: 20, Top: 172, Width: 80, Height: 15);
            Text: "";
            Style: (FontSize: 9, TextColor: #FFA500, HorizontalAlignment: Center);
        }

        Label #LeftArmFracture {
            Anchor: (Left: 410, Top: 172, Width: 80, Height: 15);
            Text: "";
            Style: (FontSize: 9, TextColor: #FFA500, HorizontalAlignment: Center);
        }

        Label #RightLegFracture {
            Anchor: (Left: 45, Top: 275, Width: 80, Height: 15);
            Text: "";
            Style: (FontSize: 9, TextColor: #FFA500, HorizontalAlignment: Center);
        }

        Label #LeftLegFracture {
            Anchor: (Left: 385, Top: 275, Width: 80, Height: 15);
            Text: "";
            Style: (FontSize: 9, TextColor: #FFA500, HorizontalAlignment: Center);
        }
    }
}

Group #TutorialBox {
    Anchor: (Left: 38.571457, Top: 25.714283, Width: 622.8571, Height: 172.85712);
    Background: "ContainerPanelLightPatch.png";
    Padding: (Full: 10);

    Label #TutorialText {
        Anchor: (Horizontal: 0, Vertical: 0);
        Text: "Welcome to MortalWounds!";
        Style: (FontSize: 14, TextColor: #FFFFFF, HorizontalAlignment: Center, VerticalAlignment: Center);
    }

    Label #PageCounter {
        Anchor: (Left: 5, Bottom: -12, Width: 100, Height: 20);
        Text: "1 / 8";
        Style: (FontSize: 10, TextColor: #AAAAAA);
    }
}

$Common.@SecondaryTextButton #BackButton {
    Anchor: (Left: 97, Top: 212, Width: 120, Height: 35);
    Text: "Back";
}

$Common.@SecondaryTextButton #NextButton {
    Anchor: (Left: 507, Top: 212, Width: 120, Height: 35);
    Text: "Next";
}

$Common.@SecondaryTextButton #CloseButton {
    Anchor: (Left: 292, Top: 211, Width: 120, Height: 35);
    Text: "Close";
}

Group #TorsoBarFrame {
    Anchor: (Left: 1052.5, Top: 304.70233, Width: 150, Height: 20);
    Padding: (Left: 2, Right: 2, Top: 2, Bottom: 2);
    Background: "ContainerPanelLightPatch.png";

    Group #TorsoBarContainer {
        Anchor: (Horizontal: 0, Vertical: 0);
        Background: "ProgressBar.png";

        ProgressBar #TorsoBar {
            BarTexturePath: "ProgressBarFill.png";
            Value: 0.9;
            EffectTexturePath: "ProgressBarEffect.png";
            EffectWidth: 68;
            EffectHeight: 20;
            EffectOffset: 0;
        }
    }
}

Group #HeadBarFrame {
    Anchor: (Left: 723.88885, Top: 245.91661, Width: 150, Height: 20);
